{
  "name": "local-llm-sidebar-chat",
  "displayName": "Local LLM Sidebar Chat",
  "description": "Start local llama.cpp servers directly from VS Code and chat with them in a premium sidebar interface.",
  "version": "0.4.0",
  "publisher": "amardeeptomar",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Productivity",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "local-llm-chat-container",
          "title": "Local LLM",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "local-llm-chat-container": [
        {
          "type": "webview",
          "id": "localLlmChatView",
          "name": "Local LLM Chat",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "localLlm.startServer",
        "title": "Local LLM: Start Server for Model",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.stopServer",
        "title": "Local LLM: Stop Active Server",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.explainCode",
        "title": "Local LLM: Explain this code",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.fixDiagnostic",
        "title": "Local LLM: Fix this error",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.indexCodebase",
        "title": "Local LLM: Index Codebase (Semantic Search)",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.clearChat",
        "title": "Local LLM: Clear Chat History",
        "category": "Local LLM"
      },
      {
        "command": "localLlm.inlineChat",
        "title": "Local LLM: Edit Inline",
        "category": "Local LLM"
      }
    ],
    "configuration": {
      "title": "Local LLM Sidebar Chat",
      "properties": {
        "localLlm.disabledTools": {
          "type": "array",
          "default": [],
          "description": "List of disabled tool IDs"
        },
        "localLlm.semanticSearch.chunkSize": {
          "type": "number",
          "default": 1000,
          "description": "The size (in characters) of each code chunk when indexing the codebase for semantic search."
        },
        "localLlm.semanticSearch.chunkOverlap": {
          "type": "number",
          "default": 200,
          "description": "The overlap (in characters) between adjacent code chunks when indexing."
        },
        "localLlm.llamaCppPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to your llama.cpp build directory (the folder containing `build-release/bin/llama-server`). Example: `/Users/you/llama.cpp`"
        },
        "localLlm.models": {
          "type": "array",
          "markdownDescription": "Configure the local models. Use the setup panel in the sidebar to add models visually, or edit this JSON directly.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique ID for the model (auto-generated if using the UI)"
              },
              "name": {
                "type": "string",
                "description": "Display name of the model in the chat panel UI"
              },
              "modelPath": {
                "type": "string",
                "description": "Absolute path to the .gguf model file (e.g. /Users/you/models/model.gguf)"
              },
              "mmprojPath": {
                "type": "string",
                "description": "Absolute path to the multimodal projector (.gguf) for vision models (e.g. /Users/you/models/mmproj.gguf)"
              },
              "contextSize": {
                "type": "number",
                "default": 4096,
                "description": "Context window size in tokens"
              },
              "gpuLayers": {
                "type": "number",
                "default": 99,
                "description": "Number of layers to offload to GPU (-ngl). Use 99 for full GPU offload."
              },
              "port": {
                "type": "number",
                "default": 8080,
                "description": "The port number on which llama-server listens"
              },
              "enableTools": {
                "type": "boolean",
                "default": false,
                "description": "Enable agentic tool calling for this model (requires a model that supports function calling)"
              },
              "command": {
                "type": "string",
                "description": "Advanced: Custom shell command override. If set, this is used instead of auto-generating from llamaCppPath + modelPath."
              }
            },
            "required": ["id", "name"]
          },
          "default": []
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "devDependencies": {
    "@types/node": "^18.17.1",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.18.11",
    "typescript": "^5.1.6"
  }
}
